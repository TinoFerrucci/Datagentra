# ──────────────────────────────────────────────────────────────────────────────
# Datagentra — Backend Environment Variables
# Copy this file to .env and fill in the required values
# ──────────────────────────────────────────────────────────────────────────────

# SQLite database paths
# Local: relative paths from backend/
# Docker: overridden automatically by docker-compose.yml
SQLITE_DB_PATH=../db/datagentra.db
CONVERSATIONS_DB_PATH=../db/conversations.db

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: 'openai' | 'ollama'
LLM_PROVIDER=openai

# OpenAI — fill in if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama — fill in if LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── App ───────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
