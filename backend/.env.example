# ──────────────────────────────────────────────────────────────────────────────
# Datagentra — Backend Environment Variables
# Copiá este archivo a .env y completá los valores necesarios
# ──────────────────────────────────────────────────────────────────────────────

# Paths a las bases de datos SQLite
# En local: paths relativos desde backend/
# En Docker: se sobreescriben automáticamente desde docker-compose.yml
SQLITE_DB_PATH=../db/datagentra.db
CONVERSATIONS_DB_PATH=../db/conversations.db

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Opciones: 'openai' | 'ollama'
LLM_PROVIDER=openai

# OpenAI — completar si LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama — completar si LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── App ───────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
